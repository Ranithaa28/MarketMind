# --- App ---
ENVIRONMENT=development
SECRET_KEY=change-me-to-a-long-random-string
ALLOWED_ORIGINS=http://localhost:3000

# --- Database (Neon-compatible Postgres) ---
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/marketmind

# --- Redis / Celery ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- Clerk Auth (get from https://dashboard.clerk.com) ---
CLERK_JWKS_URL=https://YOUR-CLERK-DOMAIN.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://YOUR-CLERK-DOMAIN.clerk.accounts.dev
CLERK_SECRET_KEY=sk_test_xxx

# --- OpenAI ---
# Default is Groq's free, OpenAI-compatible API (get a key at
# https://console.groq.com/keys -- it starts with "gsk_").
# To use real OpenAI instead: set OPENAI_BASE_URL=https://api.openai.com/v1,
# OPENAI_API_KEY to a key from https://platform.openai.com/api-keys, and
# OPENAI_MODEL to e.g. gpt-4o or gpt-4o-mini.
OPENAI_API_KEY=your_openai_or_groq_api_key_here
OPENAI_MODEL=llama-3.3-70b-versatile
OPENAI_BASE_URL=https://api.groq.com/openai/v1

# --- Search providers ---
TAVILY_API_KEY=your_tavily_api_key_here
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ENGINE_ID=
NEWSAPI_KEY=

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_ENTERPRISE=price_xxx

# --- Resend (email) ---
RESEND_API_KEY=re_xxx

# --- Cloudinary ---
CLOUDINARY_URL=cloudinary://key:secret@cloud_name

# --- Sentry ---
SENTRY_DSN=
